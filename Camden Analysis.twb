      <aliases enabled='yes' />
      <column caption='Hardship Index' datatype='real' name='[Calculation_6765345229025280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(([POVERTY_RATE] + [UNEMPLOYMENT_RATE] + [UNINSURED_RATE] + [NO_VEHICLE_PCT]) / 4, 1)' />
      </column>
      <column caption='Black Population' datatype='real' name='[Calculation_6765345230028801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[PCT_BLACK]' />
      </column>
      <column caption='Hispanic Population' datatype='real' name='[Calculation_6765345230168066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[PCT_HISPANIC]' />
      </column>
      <column caption='White Population' datatype='real' name='[Calculation_6765345230225411]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[PCT_WHITE]' />
      </column>
      <column caption='Rent Burden Pct' datatype='real' name='[Calculation_6765345231339524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND([MEDIAN_GROSS_RENT] / ([MEDIAN_INCOME] / 12) * 100, 1)' />
      </column>
      <column caption='Core Camden Avg Income' datatype='integer' name='[Calculation_6765345237123077]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ZIP_CODE] = &quot;08106&quot; THEN NULL ELSE [MEDIAN_INCOME] END' />
      </column>
      <column caption='Core Camden Avg Poverty' datatype='real' name='[Calculation_6765345237217286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ZIP_CODE] = &quot;08106&quot; THEN NULL ELSE [POVERTY_RATE] END' />
